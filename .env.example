# =============================================================================
# CODEBASE BRAIN CONFIGURATION
# =============================================================================
# Copy this file to .env and adjust values for your environment

# Repository root to index (mount point for Docker)
REPOS_ROOT=/home/rscla/repos

# Neo4j credentials
NEO4J_AUTH=neo4j/codebase-brain-dev
NEO4J_PASSWORD=codebase-brain-dev

# Embedding model (uses Ollama)
# Options ranked by speed on RTX 3070:
#   all-minilm         - 79ms/embed, 384 dims, fastest (good for dev)
#   nomic-embed-text   - 118ms/embed, 768 dims, balanced
#   mxbai-embed-large  - 122ms/embed, 1024 dims, best quality (recommended for prod)
EMBEDDING_MODEL=all-minilm
EMBEDDING_DIMENSIONS=384
OLLAMA_URL=http://host.docker.internal:11434

# Logging
LOG_LEVEL=info

# Pre-write guard behavior
# Set to 'true' to block writes that fail the guard (strict mode)
# Set to 'false' to warn but allow (advisory mode)
BLOCK_ON_FAILURE=false
